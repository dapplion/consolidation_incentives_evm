# ConsolidationIncentives deployment configuration
# Copy to contracts/.env and adjust before running forge script.

# Eligibility cutoff epoch
MAX_EPOCH=50000

# Reward per successful claim (wei)
REWARD_AMOUNT=10000000000000000

# Seconds between beacon timestamp and claim acceptance
MIN_CLAIM_DELAY=160

# Optional initial funding for the proxy during deployment (wei)
INITIAL_FUNDING=1000000000000000000

# Deployment account private key (used via --private-key or loaded by shell)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional block explorer verification key
GNOSISSCAN_API_KEY=YOUR_GNOSISSCAN_API_KEY

# Helpful RPC defaults
RPC_URL=https://rpc.chiado.gnosis.gateway.fm
